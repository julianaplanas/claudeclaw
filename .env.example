# =============================================================================
# OPENCLAW - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---- LLM Provider (choose one or both; ANTHROPIC takes priority) ------------
# Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (fallback if ANTHROPIC_API_KEY is not set)
OPENROUTER_API_KEY=sk-or-...

# Model to use (defaults shown below)
# For Anthropic: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# For OpenRouter: anthropic/claude-opus-4-6 | google/gemini-pro | openai/gpt-4o
LLM_MODEL=claude-opus-4-6

# ---- Telegram Bot ---------------------------------------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated list of Telegram user IDs allowed to use the bot
# Get your ID by messaging @userinfobot
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ---- WhatsApp via Twilio --------------------------------------------------------
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Format: whatsapp:+14155238886 (Twilio sandbox) or your approved number
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Comma-separated list of allowed WhatsApp numbers (format: whatsapp:+1234567890)
WHATSAPP_ALLOWED_NUMBERS=whatsapp:+1234567890

# ---- Google (Gmail + Calendar) --------------------------------------------------
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# Run `npm run get-google-token` after setting the above to get this
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Gmail address
GMAIL_USER=you@gmail.com

# ---- Notion (Notes) -------------------------------------------------------------
# https://www.notion.so/my-integrations → New integration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The database ID from your Notion notes database URL
# URL format: https://notion.so/yourworkspace/DATABASE_ID?v=...
NOTION_NOTES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- GitHub ---------------------------------------------------------------------
# https://github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo, workflow, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-username
# Optional: default repo for code deployments
GITHUB_DEFAULT_REPO=your-default-repo

# ---- Server / Railway -----------------------------------------------------------
PORT=3000
# Your Railway public URL (set after first deploy)
# e.g. https://openclaw-production.up.railway.app
WEBHOOK_URL=https://your-app.up.railway.app

# ---- Redis (optional, provided automatically by Railway Redis add-on) -----------
# Leave empty to use in-memory sessions (sessions lost on restart)
REDIS_URL=redis://default:password@host:6379

# ---- Security -------------------------------------------------------------------
# Secret to validate webhook calls (generate a random string)
WEBHOOK_SECRET=your-random-secret-string-here
